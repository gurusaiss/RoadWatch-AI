# ══════════════════════════════════════════════════════
#  RoadWatch — Environment Configuration Template
#  Copy this file to .env and fill in your keys
# ══════════════════════════════════════════════════════

# ── GROQ API (FREE — get key at console.groq.com) ──────
# Powers the AI chatbot with LLaMA 3.3 70B
GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI API (optional — for image damage assessment) ─
OPENAI_API_KEY=

# ══════════════════════════════════════════════════════
# Priority: GROQ_API_KEY → OPENAI_API_KEY → Rule-based
# App works fully without any API key (rule-based mode)
# ══════════════════════════════════════════════════════
