{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/index.html",        "use": "@vercel/static" },
    { "src": "frontend/css/**",            "use": "@vercel/static" },
    { "src": "frontend/js/**",             "use": "@vercel/static" },
    { "src": "frontend/manifest.json",     "use": "@vercel/static" },
    { "src": "frontend/service-worker.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)",          "dest": "/frontend/css/$1" },
    { "src": "/js/(.*)",           "dest": "/frontend/js/$1" },
    { "src": "/manifest.json",     "dest": "/frontend/manifest.json" },
    { "src": "/service-worker.js", "dest": "/frontend/service-worker.js" },
    { "src": "/api/(.*)",          "dest": "/api/index.py" },
    { "src": "/(.*)",              "dest": "/frontend/index.html" }
  ]
}
